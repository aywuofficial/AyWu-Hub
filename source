local Rayfield = loadstring(game:HttpGet('https://sirius.menu/rayfield'))()

local Window = Rayfield:CreateWindow({
   Name = "AyWu Hub V2",
   LoadingTitle = "Loading Interface...",
   LoadingSubtitle = "by AyWu",
   ConfigurationSaving = {
      Enabled = true,
      FolderName = "AyWuESP",
      FileName = "Config"
   },
   Discord = {
      Enabled = false,
      Invite = "",
      RememberJoins = true
   },
})

-- Global Variables
_G.ESP_Enabled = false
_G.Names_Enabled = false
_G.AutoClick = false
_G.AutoE = false
_G.AutoR = false
local VirtualInputManager = game:GetService("VirtualInputManager")

-- Function to create ESP for players
local function CreateESP(player)
    player.CharacterAdded:Connect(function(character)
        local hrp = character:WaitForChild("HumanoidRootPart")
        
        local highlight = Instance.new("Highlight")
        highlight.Name = "AyWuHighlight"
        highlight.Parent = character
        highlight.FillColor = Color3.fromRGB(255, 0, 0)
        highlight.OutlineColor = Color3.fromRGB(255, 255, 255)
        highlight.FillTransparency = 0.5
        highlight.Enabled = _G.ESP_Enabled

        local bill = Instance.new("BillboardGui")
        bill.Name = "AyWuName"
        bill.AlwaysOnTop = true
        bill.Size = UDim2.new(0, 100, 0, 50)
        bill.Adornee = hrp
        bill.StudsOffset = Vector3.new(0, 3, 0)
        bill.Parent = character
        bill.Enabled = _G.Names_Enabled

        local label = Instance.new("TextLabel")
        label.BackgroundTransparency = 1
        label.Size = UDim2.new(1, 0, 1, 0)
        label.Text = player.Name
        label.TextColor3 = Color3.fromRGB(255, 255, 255)
        label.TextSize = 14
        label.Parent = bill
    end)
end

-- Initialize for existing players
for _, player in pairs(game.Players:GetPlayers()) do
    if player ~= game.Players.LocalPlayer then
        if player.Character then
            task.spawn(function()
                local character = player.Character
                local highlight = Instance.new("Highlight", character)
                highlight.Name = "AyWuHighlight"
                highlight.Enabled = _G.ESP_Enabled
                
                local bill = Instance.new("BillboardGui")
                bill.Name = "AyWuName"
                bill.AlwaysOnTop = true
                bill.Size = UDim2.new(0, 100, 0, 50)
                bill.Adornee = character:WaitForChild("HumanoidRootPart")
                bill.StudsOffset = Vector3.new(0, 3, 0)
                bill.Parent = character
                bill.Enabled = _G.Names_Enabled

                local label = Instance.new("TextLabel")
                label.BackgroundTransparency = 1
                label.Size = UDim2.new(1, 0, 1, 0)
                label.Text = player.Name
                label.TextColor3 = Color3.fromRGB(255, 255, 255)
                label.Parent = bill
            end)
        end
        CreateESP(player)
    end
end

game.Players.PlayerAdded:Connect(function(player)
    if player ~= game.Players.LocalPlayer then
        CreateESP(player)
    end
end)

-- --- MAIN FEATURES TAB ---
local MainTab = Window:CreateTab("Main Features", 4483362458)

MainTab:CreateSection("Visuals")

MainTab:CreateToggle({
   Name = "Player ESP (Highlight)",
   CurrentValue = false,
   Flag = "ESP_Toggle",
   Callback = function(Value)
      _G.ESP_Enabled = Value
      for _, p in pairs(game.Players:GetPlayers()) do
          if p.Character and p.Character:FindFirstChild("AyWuHighlight") then
              p.Character.AyWuHighlight.Enabled = Value
          end
      end
   end,
})

MainTab:CreateToggle({
   Name = "Show Names",
   CurrentValue = false,
   Flag = "Names_Toggle",
   Callback = function(Value)
      _G.Names_Enabled = Value
      for _, p in pairs(game.Players:GetPlayers()) do
          if p.Character and p.Character:FindFirstChild("AyWuName") then
              p.Character.AyWuName.Enabled = Value
          end
      end
   end,
})

-- --- AUTO TAB ---
local AutoTab = Window:CreateTab("Auto Tasks", 4483362458)

AutoTab:CreateSection("Automation")

AutoTab:CreateToggle({
   Name = "Auto Left Click",
   CurrentValue = false,
   Flag = "AutoClick",
   Callback = function(Value)
      _G.AutoClick = Value
      if Value then
          task.spawn(function()
              while _G.AutoClick do
                  VirtualInputManager:SendMouseButtonEvent(0, 0, 0, true, game, 0)
                  VirtualInputManager:SendMouseButtonEvent(0, 0, 0, false, game, 0)
                  task.wait(0.1)
              end
          end)
      end
   end,
})

AutoTab:CreateToggle({
   Name = "Auto Press E",
   CurrentValue = false,
   Flag = "AutoE",
   Callback = function(Value)
      _G.AutoE = Value
      if Value then
          task.spawn(function()
              while _G.AutoE do
                  VirtualInputManager:SendKeyEvent(true, Enum.KeyCode.E, false, game)
                  task.wait(0.1)
                  VirtualInputManager:SendKeyEvent(false, Enum.KeyCode.E, false, game)
                  task.wait(0.1)
              end
          end)
      end
   end,
})

AutoTab:CreateToggle({
   Name = "Auto Press R",
   CurrentValue = false,
   Flag = "AutoR",
   Callback = function(Value)
      _G.AutoR = Value
      if Value then
          task.spawn(function()
              while _G.AutoR do
                  VirtualInputManager:SendKeyEvent(true, Enum.KeyCode.R, false, game)
                  task.wait(0.1)
                  VirtualInputManager:SendKeyEvent(false, Enum.KeyCode.R, false, game)
                  task.wait(0.1)
              end
          end)
      end
   end,
})

Rayfield:Notify({
   Title = "Hub Loaded!",
   Content = "AyWu Hub V2 is ready.",
   Duration = 5,
   Image = 4483362458,
})
